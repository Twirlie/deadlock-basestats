            "properties": {
              "value_type": {
                "type": "string"
              },
              "tier": {
                "type": "number"
              },
              "value": {
                "oneOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "string"
                  }
                ]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "cost_bonuses": {
        "type": "object",
